---
import { Image } from 'astro:assets'
import { getCollection } from 'astro:content'
import BlogList from '../components/BlogList.astro'
import ButtonLink from '../components/ButtonLink.astro'
import Spacer from '../components/Spacer.astro'
import introImage from '../data/photos/intros/intro-forest.png'
import Layout from '../layouts/Layout.astro'
import { sortBlogPosts } from '../services/date'

const posts = sortBlogPosts(await getCollection('blog'))
const recentPosts = posts.slice(0, 5)
---

<Layout
    pageTitle=""
    pageDescription="Sebastian Herrmann’s blog and website about his software projects, music, and photos."
>
    <Image
        src={introImage}
        format={introImage.format}
        alt="Photograph showing a forest trail with some thin trees."
        layout="constrained"
        width={600}
        height={200}
        loading="lazy"
        class="introImage"
    />
    <p>Hello! I’m Sebastian, a software developer from Berlin. 👋</p>
    <h2>Recent blog posts</h2>
    <BlogList posts={recentPosts} />
    <Spacer size="1rem" />
    <ButtonLink href="/blog/">See all blog posts</ButtonLink>
</Layout>

<style>
    .introImage {
        opacity: 0.75;
        margin-bottom: 0.75rem;
    }
</style>
